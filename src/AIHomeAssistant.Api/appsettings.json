{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.AspNetCore.StaticFiles": "Warning",
        "System": "Warning",
        "DbUp": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=data/aihomeassistant.db"
  },
  "HomeAssistant": {
    "BaseUrl": "",
    "Token": ""
  },
  "Azure": {
    "SpeechRegion": "italynorth",
    "SpeechKey": "",
    "OpenAiEndpoint": "",
    "OpenAiKey": "",
    "OpenAiDeployment": "gpt-4o-mini",
    "VisionEndpoint": "",
    "VisionKey": "",
    "FaceEndpoint": "",
    "FaceKey": "",
    "FacePersonGroupId": "household"
  },
  "Audio": {
    "AlsaDeviceId": "default",
    "SampleRate": 16000,
    "ChunkSize": 512,
    "FeedbackProfile": "none",
    "VoskModelPath": "config/vosk-model-en",
    "WakeWord": "jarvis",
    "SuccessSoundPath": "audio/sounds/success.wav",
    "ErrorSoundPath": "audio/sounds/error.wav"
  },
  "AllowedHosts": "*"
}
